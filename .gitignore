# Build outputs (Debug, Release, publish - all .exe/.dll land here, not in git)
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Local publish folders if you ever publish outside bin/
publish/
[Pp]ublishOutput/
out/
dist/

# WebView2 profile (cookies, cache, sessions)
WebView2Data/

# Cursor (local project cache, MCP descriptors, workspace metadata - not app source)
.cursor/

# VS Code / Cursor multi-root workspace files (often machine-specific paths)
*.code-workspace

# Visual Studio / VS Code
.vs/
.vscode/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# JetBrains Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# Test / coverage
[Tt]est[Rr]esult*/
*.coverage
*.coveragexml

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Windows shortcuts (absolute paths; keep local only)
*.lnk

# Personal Startup-folder installer (local only)
install-startup-shortcut.ps1
